# ============================================
# AI Voice Assistant - 环境变量配置
# ============================================
# 复制此文件为 .env 并填入你的 API Key
# cp .env.example .env

# 智谱 GLM-4V-Flash API Key（免费申请: https://open.bigmodel.cn/）
GLM_API_KEY=你的_GLM_API_Key_在这里

# 本地 API 代理端口（默认 3001，需与 vite.config.ts 中 proxy.target 一致）
API_PORT=3001
